server {
    listen 443 ssl;
    listen [::]:443 ssl;
    http2 on;
    server_name {{ nginx_domain }};

    proxy_headers_hash_max_size 1024;
    proxy_headers_hash_bucket_size 128;

    ssl_certificate     /etc/letsencrypt/live/{{ nginx_domain }}/fullchain.pem;
    ssl_certificate_key /etc/letsencrypt/live/{{ nginx_domain }}/privkey.pem;
    include /etc/letsencrypt/options-ssl-nginx.conf;
    ssl_dhparam /etc/letsencrypt/ssl-dhparams.pem;

    location / {
        proxy_pass http://127.0.0.1:{{ nginx_upstream_port }};
        proxy_http_version 1.1;
        proxy_set_header Upgrade $http_upgrade;
        proxy_set_header Connection "upgrade";
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;

        proxy_connect_timeout {{ proxy_timeout | default('1d') }};
        proxy_send_timeout    {{ proxy_timeout | default('1d') }};
        proxy_read_timeout    {{ proxy_timeout | default('1d') }};
    }
}

server {
    listen 80;
    listen [::]:80;
    server_name {{ nginx_domain }};

    location /.well-known/acme-challenge/ {
        root /var/www/certbot;
    }

    location / {
        return 301 https://$host$request_uri;
    }
}